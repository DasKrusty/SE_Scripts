* MATH
@variables{
    * Calculations
    a = Mass of MyShip
    b = Gravity of MyShip
    c = "0"
}

@codeblock{
    \c = math(\a*\b)
    Write to \LCST = "Mass = \a kg"
    WriteLine to \LCST = "Grav = \b"
    WriteLine to \LCST = "Force = \c Nm"
}
