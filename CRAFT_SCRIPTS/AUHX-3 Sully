* Automated systems for AUHX-3 Sully

@variables {
    * Abreviated names for blocks
	PREA = "AUHX-3 Program [EAP]"
	LILA = "AUHX-3 Light Land"
	LIFL = "AUHX-3 Light Flood"
	LINA = "AUHX-3 Light Nav"
	ECLA = "AUHX-3 Event Controller - Land"
	ECCO = "AUHX-3 Event Controller - Cockpit"
	LGHI = "AUHX-3 Hinge LG"
	LGPI = "AUHX-3 Piston LG"
	WEAT = "AUHX-3 Autocannon Turret"
	AIVE = "AUHX-3 Air Vent"
	GYR1 = "AUHX-3 Gyroscope LV.1"
	GYR2 = "AUHX-3 Gyroscope LV.2"
	GYR3 = "AUHX-3 Gyroscope LV.3"
	BAHI = "AUHX-3 Hinge Bay"
	TISH = "AUHX-3 Timer Block - Shutdown"
	TIST = "AUHX-3 Timer Block - Start"
	"AUHX-3 Antenna"
	"AUHX-3 Battery"
	"AUHX-3 Connector Below"
	"AUHX-3 Connector Rear"
	"AUHX-3 Custom Turret Controller"
	"AUHX-3 Holo LCD"
	"AUHX-3 Hydrogen Tank"
	"AUHX-3 Hydrogen Thruster"
	"AUHX-3 Landing Gear"
	"AUHX-3 Large Hydrogen Thruster"
	"AUHX-3 Light Search"
	"AUHX-3 Light Spot"
	"AUHX-3 Light Turret"
	"AUHX-3 Oxygen Tank"
}

@Test {
	Write to \PREA = "V 1.06"
	Delay 3000
	Write to \PREA = "Test Completed"
}

@Alt_Low {
	* Low Alt is triggered by an Event Controller when craft is below a set target
	Write to \PREA = "Low Altitude"
	OnOff_On \LILA
	OnOff_On \LIFL
	OnOff_Off \LINA
	OnOff_On \ECLA
	Rotate \LGHI to -45 at 5
	Move \LGPI to 0.6 at 1
}

@Alt_High {
	* Low Alt is triggered by an Event Controller when craft is below a set target
	Write to \PREA = "High Altitude"
	OnOff_Off \LILA
	OnOff_Off \LIFL
	OnOff_On \LINA
	OnOff_Off \ECLA
	Rotate \LGHI to -90 at 5
	Move \LGPI to 0 at 3
}

@Landed {
	Write to \PREA = "Landed"
	OnOff_On \ECCO
	OnOff_Off \WEAT
	Damp of MyShip = False
	Color of \LILA = 0:255:0
}

@Take_Off {
	Write to \PREA = "Lifted Off"
	OnOff_Off \ECCO
	OnOff_On \WEAT
	Damp of MyShip = True
	Color of \LILA = 255:255:255
}

@Cockpit_Out {
	OnOff_Off \AIVE
	OnOff_Off \GYR1
	OnOff_Off \GYR2
	OnOff_Off \GYR3
	Rotate \BAHI to -35 at 1
	Start \TISH
	Color of \LILA = 255:255:0
}

@Cockpit_In {
	OnOff_On \AIVE
	OnOff_On \GYR1
	Rotate \BAHI to 0 at 3
	Stop \TISH
	Start \TIST
	Color of \LILA = 0:255:0
}

