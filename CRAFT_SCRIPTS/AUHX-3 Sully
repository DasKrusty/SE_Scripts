@Alt_Low{
	* When the altitude of the craft is at a low aspect
	OnOff_On \LILA
	OnOff_Off \LINA
	Rotate \HILG to -45 @ 3
	Extend \PILG
	Write to \PREA = "LOW ALTITUDE"
}

@Alt_High{
	* When the altitude of the craft is at a high aspect
	OnOff_Off \LILA
	OnOff_On \LINA
	Rotate \HILG to -90 @ 1
	Retract \PILG
	Write to \PREA = ""
}